<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Réservation - Port Russell</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <nav>
    <span style="color:white;font-weight:bold;font-size:18px">⚓ Port Russell</span>
    <div>
      <a href="/dashboard">Tableau de bord</a>
      <a href="/catways">Catways</a>
      <a href="/logout">Se déconnecter</a>
    </div>
  </nav>

  <div class="container">
    <h1>Modifier la réservation</h1>
    <div class="card">
      <form action="/catways/<%= catwayId %>/reservations/edit/<%= reservation._id %>" method="POST">
        <label>Nom du client</label>
        <input type="text" name="clientName" value="<%= reservation.clientName %>" required>

        <label>Nom du bateau</label>
        <input type="text" name="boatName" value="<%= reservation.boatName %>" required>

        <label>Date de début</label>
        <input type="date" name="startDate" value="<%= new Date(reservation.startDate).toISOString().split('T')[0] %>" required>

        <label>Date de fin</label>
        <input type="date" name="endDate" value="<%= new Date(reservation.endDate).toISOString().split('T')[0] %>" required>

        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a href="/catways/<%= catwayId %>/reservations" class="btn btn-warning">Annuler</a>
      </form>
    </div>
  </div>

</body>
</html>