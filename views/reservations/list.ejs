<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Réservations - Port Russell</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <nav>
    <span style="color:white;font-weight:bold;font-size:18px"> Port Russell</span>
    <div>
      <a href="/dashboard">Tableau de bord</a>
      <a href="/catways">Catways</a>
      <a href="/users">Utilisateurs</a>
      <a href="/docs">Documentation</a>
      <a href="/logout">Se déconnecter</a>
    </div>
  </nav>

  <div class="container">
    <h1>Réservations du Catway N° <%= catwayId %></h1>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <div class="card">
      <h2>Ajouter une réservation</h2>
      <form action="/catways/<%= catwayId %>/reservations" method="POST">
        <label>Nom du client</label>
        <input type="text" name="clientName" required>