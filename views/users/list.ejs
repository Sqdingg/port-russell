<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Utilisateurs - Port Russell</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <nav>
    <span style="color:white;font-weight:bold;font-size:18px"> Port Russell</span>
    <div>
      <a href="/dashboard">Tableau de bord</a>
      <a href="/catways">Catways</a>
      <a href="/users">Utilisateurs</a>
      <a href="/docs">Documentation</a>
      <a href="/logout">Se déconnecter</a>
    </div>
  </nav>

  <div class="container">
    <h1>Gestion des Utilisateurs</h1>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <div class="card">
      <h2>Ajouter un utilisateur</h2>
      <form action="/users" method="POST">
        <label>Nom d'utilisateur</label>
        <input type="text" name="username" required>

        <label>Email</label>
        <input type="email" name="email" required>

        <label>Mot de passe</label>
        <input type="password" name="password" minlength="8" required>

        <button type="submit" class="btn btn-success">Ajouter</button>
      </form>
    </div>

    <h2>Liste des utilisateurs</h2>
    <table>
      <thead>
        <tr>
          <th>Nom d'utilisateur</th>
          <th>Email</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
          <tr>
            <td><%= u.username %></td>
            <td><%= u.email %></td>
            <td>
              <a href="/users/<%= u.email %>" class="btn btn-primary">Détails</a>
              <form action="/users/delete/<%= u.email %>" method="POST" style="display:inline">
                <button type="submit" class="btn btn-danger" onclick="return confirm('Supprimer cet utilisateur ?')">Supprimer</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</body>
</html>