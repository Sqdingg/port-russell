<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Utilisateur - Port Russell</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <nav>
    <span style="color:white;font-weight:bold;font-size:18px"> Port Russell</span>
    <div>
      <a href="/dashboard">Tableau de bord</a>
      <a href="/users">Utilisateurs</a>
      <a href="/logout">Se déconnecter</a>
    </div>
  </nav>

  <div class="container">
    <h1>Modifier l'utilisateur</h1>
    <div class="card">
      <form action="/users/edit/<%= foundUser.email %>" method="POST">
        <label>Nom d'utilisateur</label>
        <input type="text" name="username" value="<%= foundUser.username %>" required>

        <label>Email</label>
        <input type="email" name="email" value="<%= foundUser.email %>" required>

        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a href="/users" class="btn btn-warning">Annuler</a>
      </form>
    </div>
  </div>

</body>
</html>