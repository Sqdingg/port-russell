<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Tableau de bord - Port Russell</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <nav>
    <span style="color:white;font-weight:bold;font-size:18px"> Port Russell</span>
    <div>
      <a href="/dashboard">Tableau de bord</a>
      <a href="/catways">Catways</a>
      <a href="/catways/1/reservations">Réservations</a>
      <a href="/users">Utilisateurs</a>
      <a href="/docs">Documentation</a>
      <a href="/logout">Se déconnecter</a>
    </div>
  </nav>

  <div class="container">
    <div class="card">
      <h1>Tableau de bord</h1>
      <p><strong>Utilisateur :</strong> <%= user.username %></p>
      <p><strong>Email :</strong> <%= user.email %></p>
      <p><strong>Date du jour :</strong> <%= today %></p>
    </div>

    <h2>Réservations en cours</h2>

    <% if (reservations.length === 0) { %>
      <div class="info-box">Aucune réservation en cours.</div>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Catway N°</th>
            <th>Client</th>
            <th>Bateau</th>
            <th>Début</th>
            <th>Fin</th>
          </tr>
        </thead>
        <tbody>
          <% reservations.forEach(r => { %>
            <tr>
              <td><%= r.catwayNumber %></td>
              <td><%= r.clientName %></td>
              <td><%= r.boatName %></td>
              <td><%= new Date(r.startDate).toLocaleDateString('fr-FR') %></td>
              <td><%= new Date(r.endDate).toLocaleDateString('fr-FR') %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

</body>
</html>