<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Détails Catway - Port Russell</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <nav>
    <span style="color:white;font-weight:bold;font-size:18px"> Port Russell</span>
    <div>
      <a href="/dashboard">Tableau de bord</a>
      <a href="/catways">Catways</a>
      <a href="/catways/1/reservations">Réservations</a>
      <a href="/users">Utilisateurs</a>
      <a href="/docs">Documentation</a>
      <a href="/logout">Se déconnecter</a>
    </div>
  </nav>

  <div class="container">
    <h1>Détails du Catway N° <%= catway.catwayNumber %></h1>

    <div class="card">
      <p><strong>Numéro :</strong> <%= catway.catwayNumber %></p>
      <p><strong>Type :</strong> <%= catway.catwayType %></p>
      <p><strong>État :</strong> <%= catway.catwayState %></p>
    </div>

    <div class="card">
      <h2>Modifier l'état</h2>
      <form action="/catways/edit/<%= catway.catwayNumber %>" method="POST">
        <label>Nouvel état</label>
        <textarea name="catwayState" rows="3" required><%= catway.catwayState %></textarea>
        <button type="submit" class="btn btn-primary">Modifier</button>
      </form>
    </div>

    <a href="/catways" class="btn btn-warning">← Retour à la liste</a>
    <a href="/catways/<%= catway.catwayNumber %>/reservations" class="btn btn-success">Voir les réservations</a>
  </div>

</body>
</html>