<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Modifier Catway - Port Russell</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <nav>
    <span style="color:white;font-weight:bold;font-size:18px">⚓ Port Russell</span>
    <div>
      <a href="/dashboard">Tableau de bord</a>
      <a href="/catways">Catways</a>
      <a href="/logout">Se déconnecter</a>
    </div>
  </nav>

  <div class="container">
    <h1>Modifier le Catway</h1>
    <div class="card">
      <form action="/catways/edit/<%= catway.catwayNumber %>" method="POST">
        <label>État</label>
        <textarea name="catwayState" rows="3" required><%= catway.catwayState %></textarea>
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a href="/catways" class="btn btn-warning">Annuler</a>
      </form>
    </div>
  </div>

</body>
</html>